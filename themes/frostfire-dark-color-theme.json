{
  "name": "Frostfire Dark",
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",
  "colors": {
    // Nord palette used here:
    // Polar Night: nord0=#2E3440  nord1=#3B4252  nord2=#434C5E  nord3=#4C566A
    // Snow Storm:  nord4=#D8DEE9  nord5=#E5E9F0  nord6=#ECEFF4
    // Frost:       nord7=#8FBCBB  nord8=#88C0D0  nord9=#81A1C1  nord10=#5E81AC
    // Aurora:      nord11=#BF616A nord12=#D08770 nord13=#EBCB8B nord14=#A3BE8C nord15=#B48EAD

    // ── Editor ────────────────────────────────────────────────────────────
    "editor.background": "#2E3440",
    "editor.foreground": "#D8DEE9",
    "editor.lineHighlightBackground": "#3B425250",
    "editor.selectionBackground": "#434C5E80",
    "editor.selectionHighlightBackground": "#434C5E50",
    "editor.inactiveSelectionBackground": "#434C5E40",
    "editor.wordHighlightBackground": "#88C0D020",
    "editor.wordHighlightStrongBackground": "#88C0D040",
    "editor.findMatchBackground": "#EBCB8B60",
    "editor.findMatchHighlightBackground": "#EBCB8B30",
    "editor.hoverHighlightBackground": "#88C0D020",
    "editorLineNumber.foreground": "#4C566A",
    "editorLineNumber.activeForeground": "#D8DEE9",
    "editorCursor.foreground": "#D8DEE9",
    "editorCursor.background": "#2E3440",
    "editorIndentGuide.background1": "#3B4252",
    "editorIndentGuide.activeBackground1": "#4C566A",
    "editorRuler.foreground": "#3B4252",
    "editorCodeLens.foreground": "#4C566A",
    "editorBracketMatch.background": "#88C0D030",
    "editorBracketMatch.border": "#88C0D0",
    "editorGutter.background": "#2E3440",
    "editorGutter.addedBackground": "#A3BE8C",
    "editorGutter.deletedBackground": "#BF616A",
    "editorGutter.modifiedBackground": "#EBCB8B",
    "editorWhitespace.foreground": "#3B4252",
    "editorOverviewRuler.border": "#2E3440",
    "editorOverviewRuler.findMatchForeground": "#EBCB8B",
    "editorOverviewRuler.selectionHighlightForeground": "#434C5E",
    "editorOverviewRuler.addedForeground": "#A3BE8C",
    "editorOverviewRuler.deletedForeground": "#BF616A",
    "editorOverviewRuler.modifiedForeground": "#EBCB8B",
    "editorOverviewRuler.errorForeground": "#BF616A",
    "editorOverviewRuler.warningForeground": "#EBCB8B",
    "editorError.foreground": "#BF616A",
    "editorWarning.foreground": "#EBCB8B",
    "editorInfo.foreground": "#81A1C1",
    "editorHint.foreground": "#A3BE8C",

    // ── Diff editor ───────────────────────────────────────────────────────
    "diffEditor.insertedTextBackground": "#A3BE8C18",
    "diffEditor.removedTextBackground": "#BF616A18",
    "diffEditor.insertedLineBackground": "#A3BE8C10",
    "diffEditor.removedLineBackground": "#BF616A10",

    // ── Widget / dropdown ─────────────────────────────────────────────────
    "editorWidget.background": "#3B4252",
    "editorWidget.border": "#434C5E",
    "editorWidget.foreground": "#D8DEE9",
    "editorSuggestWidget.background": "#3B4252",
    "editorSuggestWidget.border": "#434C5E",
    "editorSuggestWidget.foreground": "#D8DEE9",
    "editorSuggestWidget.highlightForeground": "#88C0D0",
    "editorSuggestWidget.selectedBackground": "#434C5E",
    "editorHoverWidget.background": "#3B4252",
    "editorHoverWidget.border": "#434C5E",

    // ── Sidebar & Explorer ────────────────────────────────────────────────
    "sideBar.background": "#2E3440",
    "sideBar.foreground": "#D8DEE9",
    "sideBar.border": "#3B4252",
    "sideBarTitle.foreground": "#88C0D0",
    "sideBarSectionHeader.background": "#3B4252",
    "sideBarSectionHeader.foreground": "#88C0D0",
    "sideBarSectionHeader.border": "#434C5E",
    "list.activeSelectionBackground": "#434C5E",
    "list.activeSelectionForeground": "#ECEFF4",
    "list.hoverBackground": "#3B425280",
    "list.hoverForeground": "#D8DEE9",
    "list.inactiveSelectionBackground": "#3B4252",
    "list.inactiveSelectionForeground": "#D8DEE9",
    "list.focusBackground": "#434C5E",
    "list.highlightForeground": "#88C0D0",
    "listFilterWidget.background": "#3B4252",
    "listFilterWidget.outline": "#434C5E",

    // ── Activity Bar ──────────────────────────────────────────────────────
    "activityBar.background": "#2E3440",
    "activityBar.foreground": "#D8DEE9",
    "activityBar.inactiveForeground": "#81A1C1",
    "activityBar.border": "#3B4252",
    "activityBarBadge.background": "#88C0D0",
    "activityBarBadge.foreground": "#2E3440",

    // ── Status Bar ────────────────────────────────────────────────────────
    "statusBar.background": "#2E3440",
    "statusBar.foreground": "#D8DEE9",
    "statusBar.border": "#3B4252",
    "statusBar.debuggingBackground": "#BF616A",
    "statusBar.debuggingForeground": "#ECEFF4",
    "statusBar.noFolderBackground": "#3B4252",
    "statusBarItem.hoverBackground": "#3B4252",
    "statusBarItem.activeBackground": "#434C5E",
    "statusBarItem.remoteBackground": "#5E81AC",
    "statusBarItem.remoteForeground": "#ECEFF4",

    // ── Title Bar ─────────────────────────────────────────────────────────
    "titleBar.activeBackground": "#2E3440",
    "titleBar.activeForeground": "#D8DEE9",
    "titleBar.inactiveBackground": "#2E3440",
    "titleBar.inactiveForeground": "#4C566A",
    "titleBar.border": "#3B4252",

    // ── Tabs ──────────────────────────────────────────────────────────────
    "editorGroupHeader.tabsBackground": "#2E3440",
    "editorGroupHeader.tabsBorder": "#3B4252",
    "tab.activeBackground": "#3B4252",
    "tab.activeForeground": "#ECEFF4",
    "tab.activeBorder": "#88C0D0",
    "tab.inactiveBackground": "#3B4252",
    "tab.inactiveForeground": "#81A1C1",
    "tab.hoverBackground": "#3B425280",
    "tab.border": "#2E3440",
    "tab.unfocusedActiveBackground": "#3B4252",
    "tab.unfocusedActiveForeground": "#D8DEE9",
    "tab.unfocusedInactiveForeground": "#4C566A",

    // ── Panel (Terminal) ──────────────────────────────────────────────────
    "panel.background": "#2E3440",
    "panel.border": "#3B4252",
    "panelTitle.activeBorder": "#88C0D0",
    "panelTitle.activeForeground": "#D8DEE9",
    "panelTitle.inactiveForeground": "#81A1C1",
    "terminal.background": "#2E3440",
    "terminal.foreground": "#D8DEE9",
    "terminal.ansiBlack": "#3B4252",
    "terminal.ansiBlue": "#5E81AC",
    "terminal.ansiBrightBlack": "#4C566A",
    "terminal.ansiBrightBlue": "#81A1C1",
    "terminal.ansiBrightCyan": "#8FBCBB",
    "terminal.ansiBrightGreen": "#A3BE8C",
    "terminal.ansiBrightMagenta": "#B48EAD",
    "terminal.ansiBrightRed": "#BF616A",
    "terminal.ansiBrightWhite": "#ECEFF4",
    "terminal.ansiBrightYellow": "#EBCB8B",
    "terminal.ansiCyan": "#88C0D0",
    "terminal.ansiGreen": "#A3BE8C",
    "terminal.ansiMagenta": "#B48EAD",
    "terminal.ansiRed": "#BF616A",
    "terminal.ansiWhite": "#D8DEE9",
    "terminal.ansiYellow": "#EBCB8B",
    "terminal.selectionBackground": "#434C5E60",
    "terminalCursor.foreground": "#D8DEE9",

    // ── Input / Search ────────────────────────────────────────────────────
    "input.background": "#3B4252",
    "input.border": "#434C5E",
    "input.foreground": "#D8DEE9",
    "input.placeholderForeground": "#4C566A",
    "inputOption.activeBackground": "#434C5E",
    "inputOption.activeForeground": "#ECEFF4",
    "inputValidation.errorBackground": "#BF616A20",
    "inputValidation.errorBorder": "#BF616A",
    "inputValidation.warningBackground": "#EBCB8B20",
    "inputValidation.warningBorder": "#EBCB8B",
    "inputValidation.infoBackground": "#81A1C120",
    "inputValidation.infoBorder": "#81A1C1",
    "searchEditor.findMatchBackground": "#EBCB8B40",

    // ── Buttons ───────────────────────────────────────────────────────────
    "button.background": "#5E81AC",
    "button.foreground": "#ECEFF4",
    "button.hoverBackground": "#81A1C1",
    "button.secondaryBackground": "#434C5E",
    "button.secondaryForeground": "#D8DEE9",
    "button.secondaryHoverBackground": "#4C566A",

    // ── Scrollbar ─────────────────────────────────────────────────────────
    "scrollbar.shadow": "#00000040",
    "scrollbarSlider.background": "#434C5E60",
    "scrollbarSlider.hoverBackground": "#434C5E80",
    "scrollbarSlider.activeBackground": "#4C566AA0",

    // ── Notifications ─────────────────────────────────────────────────────
    "notifications.background": "#3B4252",
    "notifications.foreground": "#D8DEE9",
    "notifications.border": "#434C5E",
    "notificationLink.foreground": "#88C0D0",
    "notificationsErrorIcon.foreground": "#BF616A",
    "notificationsWarningIcon.foreground": "#EBCB8B",
    "notificationsInfoIcon.foreground": "#81A1C1",

    // ── Git Decorations ───────────────────────────────────────────────────
    "gitDecoration.addedResourceForeground": "#A3BE8C",
    "gitDecoration.conflictingResourceForeground": "#EBCB8B",
    "gitDecoration.deletedResourceForeground": "#BF616A",
    "gitDecoration.ignoredResourceForeground": "#4C566A",
    "gitDecoration.modifiedResourceForeground": "#81A1C1",
    "gitDecoration.renamedResourceForeground": "#B48EAD",
    "gitDecoration.untrackedResourceForeground": "#A3BE8C",
    "gitDecoration.stageAddedResourceForeground": "#A3BE8C",
    "gitDecoration.stageDeletedResourceForeground": "#BF616A",
    "gitDecoration.stageModifiedResourceForeground": "#EBCB8B",

    // ── Breadcrumbs ───────────────────────────────────────────────────────
    "breadcrumb.background": "#2E3440",
    "breadcrumb.foreground": "#4C566A",
    "breadcrumb.focusForeground": "#D8DEE9",
    "breadcrumb.activeSelectionForeground": "#88C0D0",
    "breadcrumbPicker.background": "#3B4252",

    // ── Peek view ─────────────────────────────────────────────────────────
    "peekView.border": "#88C0D0",
    "peekViewEditor.background": "#2E3440",
    "peekViewEditor.matchHighlightBackground": "#EBCB8B30",
    "peekViewResult.background": "#2E3440",
    "peekViewResult.fileForeground": "#D8DEE9",
    "peekViewResult.lineForeground": "#D8DEE9",
    "peekViewResult.matchHighlightBackground": "#EBCB8B40",
    "peekViewResult.selectionBackground": "#434C5E",
    "peekViewResult.selectionForeground": "#ECEFF4",
    "peekViewTitle.background": "#3B4252",
    "peekViewTitleDescription.foreground": "#88C0D0",
    "peekViewTitleLabel.foreground": "#D8DEE9",

    // ── Misc ──────────────────────────────────────────────────────────────
    "focusBorder": "#88C0D0",
    "foreground": "#D8DEE9",
    "disabledForeground": "#4C566A",
    "widget.shadow": "#00000060",
    "selection.background": "#434C5E60",
    "descriptionForeground": "#4C566A",
    "errorForeground": "#BF616A",
    "icon.foreground": "#88C0D0",
    "badge.background": "#88C0D0",
    "badge.foreground": "#2E3440",
    "progressBar.background": "#88C0D0",
    "textLink.foreground": "#88C0D0",
    "textLink.activeForeground": "#8FBCBB",
    "textBlockQuote.background": "#3B4252",
    "textBlockQuote.border": "#88C0D0",
    "textCodeBlock.background": "#3B4252",
    "textPreformat.foreground": "#A3BE8C",
    "textSeparator.foreground": "#434C5E",
    "dropdown.background": "#3B4252",
    "dropdown.border": "#434C5E",
    "dropdown.foreground": "#D8DEE9",
    "checkbox.background": "#3B4252",
    "checkbox.border": "#434C5E",
    "menu.background": "#3B4252",
    "menu.foreground": "#D8DEE9",
    "menu.selectionBackground": "#434C5E",
    "menu.selectionForeground": "#ECEFF4",
    "menu.separatorBackground": "#434C5E",
    "menu.border": "#434C5E",
    "menubar.selectionBackground": "#434C5E",
    "menubar.selectionForeground": "#D8DEE9",
    "pickerGroup.border": "#434C5E",
    "pickerGroup.foreground": "#88C0D0",
    "quickInput.background": "#3B4252",
    "quickInput.foreground": "#D8DEE9",
    "quickInputHighlight.background": "#88C0D030",
    "keybindingLabel.background": "#434C5E",
    "keybindingLabel.border": "#4C566A",
    "keybindingLabel.foreground": "#D8DEE9"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#ABB2BF", "fontStyle": "italic" }
    },
    {
      "name": "Variable",
      "scope": ["string constant.other.placeholder", "entity.name.variable"],
      "settings": { "foreground": "#FFFFFF" }
    },
    {
      "name": "Function Parameter",
      "scope": "variable.parameter",
      "settings": { "foreground": "#e5c07b" }
    },
    {
      "name": "Function Argument",
      "scope": ["meta.function-call.arguments"],
      "settings": { "foreground": "#FFFFFF" }
    },
    {
      "name": "Colors",
      "scope": ["constant.other.color"],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Keyword, Storage",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other.unit",
        "keyword.other",
        "keyword.other.template"
      ],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "Storage",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "constant.other.color",
        "punctuation",
        "meta.tag",
        "punctuation.definition.tag",
        "punctuation.separator.inheritance.php",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.section.embedded",
        "keyword.other.substitution"
      ],
      "settings": { "foreground": "#ffffff" }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag", "meta.tag.sgml", "markup.deleted.git_gutter"],
      "settings": { "foreground": "#f07178" }
    },
    {
      "name": "Function, Special Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Number, Constant, Tag Attribute, Embedded",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character",
        "constant.escape"
      ],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Block Level Variables",
      "scope": ["meta.block variable.other"],
      "settings": { "foreground": "#f07178" }
    },
    {
      "name": "Other Variable, String Link",
      "scope": ["support.other.variable", "string.other.link"],
      "settings": { "foreground": "#f07178" }
    },
    {
      "name": "Strings",
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#98C379" }
    },
    {
      "name": "String, Symbols, Inherited Class, Markup Heading",
      "scope": [
        "constant.other.symbol",
        "constant.other.key",
        "entity.other.inherited-class",
        "meta.class.inheritance",
        "markup.heading",
        "markup.inserted.git_gutter",
        "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": { "foreground": "#F69D50" }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.class",
        "support.orther.namespace.use.php",
        "meta.use.php",
        "support.other.namespace.php",
        "markup.changed.git_gutter",
        "support.type.sys-types"
      ],
      "settings": { "foreground": "#F69D50" }
    },
    {
      "name": "Language methods",
      "scope": ["variable.language"],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Function Decorator",
      "scope": [
        "punctuation.definition.decorator",
        "meta.function.decorator",
        "entity.name.function.decorator"
      ],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "CSS Class and Support",
      "scope": [
        "source.css support.type.property-name",
        "source.sass support.type.property-name",
        "source.scss support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name"
      ],
      "settings": { "foreground": "#B2CCD6" }
    },
    {
      "name": "Sub-methods",
      "scope": [
        "entity.name.module.js",
        "variable.import.parameter.js",
        "variable.other.class.js"
      ],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "entity.name.method.js",
      "scope": ["entity.name.method.js"],
      "settings": { "fontStyle": "italic", "foreground": "#82AAFF" }
    },
    {
      "name": "meta.method.js",
      "scope": [
        "meta.class-method.js entity.name.function.js",
        "variable.function.constructor"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": { "fontStyle": "italic", "foreground": "#FFCB6B" }
    },
    {
      "name": "CSS Classes",
      "scope": ["entity.other.attribute-name.class"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "CSS ID's",
      "scope": ["source.sass keyword.control"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "Deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "Regular Expressions",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Escape Characters",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "URL",
      "scope": ["*url*", "*link*", "*uri*"],
      "settings": { "fontStyle": "underline" }
    },
    {
      "name": "Decorators",
      "scope": [
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js punctuation.definition.tag.js"
      ],
      "settings": { "fontStyle": "italic", "foreground": "#82AAFF" }
    },
    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": { "foreground": "#F69D50" }
    },
    {
      "name": "JSON Key - Level 1",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "JSON Key - Level 2",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": { "foreground": "#F78C6C" }
    },
    {
      "name": "JSON Key - Level 3+",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": { "foreground": "#FF5370" }
    },
    {
      "name": "Markdown - Plain",
      "scope": [
        "text.html.markdown",
        "punctuation.definition.list_item.markdown"
      ],
      "settings": { "foreground": "#EEFFFF" }
    },
    {
      "name": "Markdown - Heading",
      "scope": [
        "markup.heading | markup.heading entity.name",
        "markup.heading.markdown punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "Markup - Italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic", "foreground": "#f07178" }
    },
    {
      "name": "Markup - Bold",
      "scope": ["markup.bold", "markup.bold string"],
      "settings": { "fontStyle": "bold", "foreground": "#f07178" }
    },
    {
      "name": "Markup - Underline",
      "scope": ["markup.underline"],
      "settings": { "fontStyle": "underline", "foreground": "#F78C6C" }
    },
    {
      "name": "Markdown - Link",
      "scope": ["string.other.link.title.markdown"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Markdown - Link Description",
      "scope": ["string.other.link.description.title.markdown"],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "Markdown - Link Anchor",
      "scope": ["constant.other.reference.link.markdown"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "Markup - Raw Block",
      "scope": ["markup.raw.block"],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "Markup - Table",
      "scope": ["markup.table"],
      "settings": { "foreground": "#EEFFFF" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable.declaration": { "bold": true },
    "variable.decorator": "#FF5370",
    "method.decorator": "#FF5370",
    "function": "#82AAFF",
    "method": "#82AAFF",
    "class": "#F69D50",
    "enum": "#F69D50",
    "interface": { "foreground": "#F69D50", "fontStyle": "italic" },
    "type": "#F69D50",
    "parameter": "#e5c07b",
    "variable": "#FFFFFF",
    "property": "#f07178",
    "enumMember": "#FF5370",
    "keyword": "#C792EA",
    "comment": { "foreground": "#ABB2BF", "fontStyle": "italic" },
    "string": "#98C379",
    "number": "#FF5370",
    "operator": "#FF5370",
